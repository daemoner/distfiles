URxvt.scrollBar: false

! Background color
URxvt*background: black

! Цвет шрифта
URxvt*foreground: #FFFFFF

! black
URxvt.color0: #000000
URxvt.color8: #000000

! red
URxvt.color1: #FF0000
URxvt.color9: #FF0000

! green
URxvt.color2:  #00FF00
URxvt.color10: #00FF00

! yellow
URxvt.color3:  #FFFF00
URxvt.color11: #FFFF00

! blue
URxvt.color4:  #0000FF
URxvt.color12: #0000FF

! magenta
URxvt.color5:  #FF00FF
URxvt.color13: #FF00FF

! cyan
URxvt.color6:  #00FFFF
URxvt.color14: #00FFFF

! white
URxvt.color7:  #FFFFFF
URxvt.color15: #FFFFFF

!fonts
URxvt.font: xft:Hack-Regular:pixelsize=13
URxvt.boltFont: xft:Hack-Regular:pixelsize=13

URxvt.letterSpace: 0

! Цвет текста, находящегося под курсором
URxvt.cursorColor2: red


! Будет ли курсор мигать
URxvt.cursorBlink: true


! Псевдопрозрачность - в кач-ве фона
! поставить обои рабочего стола
URxvt*transparent: true

! Яркость прозрачного фона (-100 .. 100)
URxvt*shading: 50

! Та же псевдопрозрачность, без настройки яркости
URxvt.inheritPixmap: true

! Внешняя программа для открытия ссылок
URxvt.urlLauncher: firefox

! Кнопка мыши, которая открывает ссылку
URxvt.matcher.button: 1
